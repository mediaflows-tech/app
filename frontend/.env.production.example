# Example production environment for the MediaFlows frontend.
#
# Copy this file to `.env.production` (gitignored) and fill in the real values,
# or inject them via Amplify Hosting environment variables at deploy time.

# API
API_BASE_URL=https://api.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.example.com

# CDN + SignalR (public)
NEXT_PUBLIC_CDN_URL=https://cdn.example.com
NEXT_PUBLIC_SIGNALR_URL=https://api.example.com/hubs

# NextAuth — frontend deployment URL
NEXTAUTH_URL=https://web.example.com
AUTH_URL=https://web.example.com
AUTH_TRUST_HOST=true

# Cognito — replace pool/client IDs with values from your Cognito user pool
COGNITO_ISSUER=https://cognito-idp.<region>.amazonaws.com/<region>_XXXXXXXXX
COGNITO_CLIENT_ID=<cognito-app-client-id>
NEXT_PUBLIC_COGNITO_USER_POOL_ID=<region>_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=<cognito-app-client-id>

# Server-side secrets — generate with:
#   openssl rand -base64 32         (NEXTAUTH_SECRET / AUTH_SECRET — same value)
#   from Cognito console            (COGNITO_CLIENT_SECRET)
# In production these should be sourced from SSM at /mediaflows/prod/*
NEXTAUTH_SECRET=<generate-with-openssl-rand-base64-32>
AUTH_SECRET=<same-value-as-NEXTAUTH_SECRET>
COGNITO_CLIENT_SECRET=<cognito-app-client-secret>

SSM_SECRETS_PATH=/mediaflows/prod/
