{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Port=5432;Database=mediaflows;Username=postgres;Password=postgres"
  },
  "AWS": {
    "Region": "ap-southeast-1"
  },
  "Cognito": {
    "Authority": "https://cognito-idp.ap-southeast-1.amazonaws.com/ap-southeast-1_XXXXXXXXX",
    "ClientId": "your-client-id",
    "ClientSecret": "your-client-secret",
    "Domain": "https://mediaflows.auth.ap-southeast-1.amazoncognito.com",
    "UserPoolId": "ap-southeast-1_XXXXXXXXX",
    "LogoutUri": "https://localhost:5001"
  },
  "Rekognition": {
    "Enabled": false,
    "BucketName": "mediaflows-assets-dev",
    "AssetUploadedTopicArn": ""
  },
  "S3": {
    "BucketName": "mediaflows-assets-dev",
    "CloudFrontDomain": "",
    "PresignedUrlExpirationMinutes": 15,
    "MaxFileSizeBytes": 5368709120
  },
  "EventBridge": {
    "BusName": ""
  },
  "Jwt": {
    "Authority": "https://cognito-idp.ap-southeast-1.amazonaws.com/ap-southeast-1_XXXXXXXXX"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000", "https://main.d1234567890.amplifyapp.com"]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
