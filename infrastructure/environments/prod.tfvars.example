# infrastructure/environments/prod.tfvars.example
# Copy to prod.tfvars (committed since secrets are externalized to SSM)
# and adjust per-environment values. Used by MediaFlows.Web.Tests.Infrastructure
# .StorageCorsContractTests as the contract reference.

environment = "prod"

# GitHub repo identity — propagated from the bootstrap stack so OIDC trust
# matches the actual repo.
github_owner = "mediaflows-tech"
github_repo  = "app"

db_instance_class    = "db.t3.micro"
db_allocated_storage = 20
eb_instance_type     = "t3.micro"
eb_min_instances     = 1
eb_max_instances     = 4
lambda_memory_size   = 512
lambda_timeout       = 60

# Custom domain — Amplify owns apex via aws_amplify_domain_association,
# Cognito hosted UI at auth.${domain}.
domain_name = "example.com"

# Amplify cutover (legacy) — kept for the case where you ever need to
# flip apex Route53 alias between EB and Amplify CloudFront manually.
# Not needed during normal operation.
amplify_cutover        = false
amplify_cloudfront_dns = ""

# NextAuth callback + logout URLs on Cognito. The callback path matches
# the NextAuth convention: /api/auth/callback/cognito.
cognito_callback_urls = [
  "https://example.com/api/auth/callback/cognito",
  "http://localhost:3000/api/auth/callback/cognito",
]

cognito_logout_urls = [
  "https://example.com",
  "http://localhost:3000",
]

# S3 CORS for browser-to-S3 presigned uploads.
cors_allowed_origins = [
  "https://example.com",
  "http://localhost:3000",
]
